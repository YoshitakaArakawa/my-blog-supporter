# Playwright session cache (X login cookies etc.)
.playwright-cli/
# Playwright MCP browser working dir (snapshots / screenshots)
.playwright-mcp/

# Third-party raw references (copyright)
output/*/references/

# Wix dashboard snapshots (account IDs / embeds; import source only)
output/**/*.mhtml

# Claude Code settings (local-only)
.claude/settings.json
.claude/settings.local.json

# Images & illustration sources (article screenshots / figure sources)
*.png
*.html
*.svg

# OS metadata
Thumbs.db
.DS_Store
